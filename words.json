*{box-sizing:border-box}body{margin:0;font-family:Arial,"Microsoft YaHei",sans-serif;background:#eef2ff;color:#111827}button{cursor:pointer}.start{min-height:100vh;background:linear-gradient(135deg,#4f46e5,#7c3aed);display:flex;align-items:center;justify-content:center;padding:22px}.startCard{background:white;border-radius:34px;max-width:980px;width:100%;padding:42px;box-shadow:0 24px 55px #0003;text-align:center}.startTitle{font-size:42px;font-weight:950;color:#4f46e5}.choiceGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:25px 0}.choice{border:3px solid #d8d8df;border-radius:22px;padding:20px;font-size:22px;font-weight:950;background:#f8fafc}.choice.active{background:#4f46e5;color:white;border-color:#4f46e5}.startBtn{width:100%;border:0;border-radius:22px;background:#46a35a;color:white;font-size:28px;font-weight:950;padding:20px}header{background:linear-gradient(135deg,#4f46e5,#7c3aed);color:white;text-align:center;padding:20px}.badge{display:inline-block;background:white;color:#4f46e5;border-radius:999px;padding:7px 12px;margin:4px;font-weight:900;border:0}main{max-width:1200px;margin:auto;padding:16px}.panel{background:white;border-radius:22px;padding:20px;box-shadow:0 8px 26px #0002;margin-bottom:18px}.nav{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}.btn{padding:13px;border:2px solid #c7d2fe;border-radius:16px;background:#f8fafc;color:#4f46e5;font-weight:900}.btn.active{background:#4f46e5;color:white}.input{width:100%;padding:13px;border:2px solid #c7d2fe;border-radius:16px;margin:10px 0;font-weight:800}.chipGrid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px}.wordBtn{display:block;width:100%;text-align:left;margin:7px 0;padding:14px;border:2px solid #c7d2fe;border-radius:16px;background:white;color:#4f46e5;font-size:17px}.card{background:#f8fafc;border:2px solid #c7d2fe;border-radius:18px;padding:16px;margin:6px 0 14px;line-height:1.75}.big{font-size:28px;font-weight:950;color:#4f46e5}.gameBox{background:#eef2ff;border-radius:22px;padding:18px;margin-top:12px}.memoryGrid{display:grid;grid-template-columns:repeat(auto-fill,110px);gap:12px;justify-content:center}.memoryCard{width:110px;height:110px;border:2px solid #c7d2fe;border-radius:18px;background:white;color:#4f46e5;font-weight:950;display:flex;align-items:center;justify-content:center;text-align:center;padding:8px;word-break:break-word}.done{background:#bbf7d0!important;color:#166534!important;border-color:#16a34a!important}.matchRow{display:grid;grid-template-columns:1fr 50px 1fr;gap:10px;align-items:center;margin:10px 0}.matchCard{min-height:78px;border:3px solid #c7d2fe;border-radius:18px;background:white;color:#4f46e5;font-weight:950;padding:10px;text-align:center}.froggy{max-width:850px;margin:auto;background:#7db33a;border-radius:12px;overflow:hidden;border:4px solid #496d1e}.frogTop{height:72px;background:#75a832;color:white;display:flex;align-items:center;justify-content:space-between;padding:10px 22px;font-weight:950}.frogQuestion{background:white;border:3px solid #75a832;border-radius:12px;margin:12px;padding:14px;text-align:center;font-size:22px;font-weight:950}.pond{position:relative;min-height:360px;background:#62c7f4;overflow:hidden}.pad{position:absolute;width:150px;height:120px;border-radius:50%;background:#183911;color:white;display:flex;align-items:center;justify-content:center;text-align:center;font-size:22px;font-weight:950;box-shadow:0 8px 0 #0d2609;border:0;cursor:pointer}.pad span{position:absolute;top:-18px;background:#7fbe34;border-radius:999px;padding:8px 14px}.padA{left:8%;top:125px}.padB{left:40%;top:50px}.padC{right:8%;top:125px}.frog{position:absolute;left:50%;bottom:30px;transform:translateX(-50%);font-size:72px;transition:left .8s cubic-bezier(.2,1.25,.35,1),bottom .8s cubic-bezier(.2,1.25,.35,1),transform .8s ease;z-index:5}.frog.jumpA{left:16%;bottom:145px;transform:translateX(-50%) scale(1.12)}.frog.jumpB{left:48%;bottom:220px;transform:translateX(-50%) scale(1.12)}.frog.jumpC{left:79%;bottom:145px;transform:translateX(-50%) scale(1.12)}.frog.sink{bottom:-90px;transform:translateX(-50%) rotate(90deg);opacity:.75}.frogFeed{background:white;margin:12px;border-radius:12px;min-height:42px;padding:10px;text-align:center;font-weight:950}.feedback{background:white;border-radius:16px;min-height:45px;padding:12px;text-align:center;font-weight:950;max-width:760px;margin:12px auto}@media(max-width:800px){.choiceGrid,.nav{grid-template-columns:1fr}.matchRow{grid-template-columns:1fr 30px 1fr}.pad{width:110px;height:90px;font-size:15px}.frog{font-size:56px}.padA{left:2%}.padB{left:36%}.padC{right:2%}}
.dictBox{margin-top:14px}
.dictBtn{display:inline-block;background:#16a34a;color:white;text-decoration:none;border-radius:14px;padding:12px 16px;font-weight:950}
.dictBtn:hover{filter:brightness(1.08)}

.dictBtn2{margin-left:8px;background:#2563eb}
@media(max-width:800px){.dictBtn2{margin-left:0;margin-top:8px}}

.onlineDictPanel{background:#fff7ed;border:2px solid #fed7aa;border-radius:18px;padding:14px;margin:0 0 16px}
.dictLinkGrid{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.smallDictBtn{display:inline-block;background:#f97316;color:white;text-decoration:none;border-radius:12px;padding:9px 12px;font-weight:900}
.smallDictBtn:hover{filter:brightness(1.08)}

.notFoundBox{background:#fee2e2;border:2px solid #fecaca;color:#991b1b;border-radius:16px;padding:14px;margin:12px 0;font-weight:900}
.alwaysDict{background:#ecfeff;border-color:#a5f3fc}

.roundTitle{text-align:center;font-size:22px;font-weight:950;color:#4f46e5;margin:8px 0 16px}
.matchGrid{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start}
.matchGrid .matchCard{display:block;width:100%;margin:10px 0}
.matchCard.selected{background:#fef3c7!important;border-color:#f59e0b!important;color:#92400e!important}
@media(max-width:800px){.matchGrid{grid-template-columns:1fr}}

.levelNotice{text-align:center;background:#eef2ff;border:2px solid #c7d2fe;color:#4f46e5;border-radius:16px;padding:10px;margin:12px 0;font-weight:950}
.padD{left:25%;top:205px}
.padE{right:25%;top:205px}
